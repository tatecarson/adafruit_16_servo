#pragma once

// Copy this file to Secrets.h and fill in your real credentials.
// Secrets.h is gitignored — your actual passwords never get committed.

// Wi-Fi network the boards join. UNO R4 WiFi only supports 2.4 GHz WPA2-PSK.
#define WIFI_SSID "your-ssid-here"
#define WIFI_PASS "your-wifi-password-here"

// HTTP Basic Auth credentials for OTA uploads (the curl --user value).
// Username is fixed to "arduino" by the ArduinoOTA library; only the password
// can change. Pick something better than "password" for the install.
#define OTA_PASSWORD "your-ota-password-here"

// Hostname advertised on the OTA service.
#define OTA_HOSTNAME "ArduinoOTA_Test"
